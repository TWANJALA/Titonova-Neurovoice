VITE_FIREBASE_API_KEY=replace-me
VITE_FIREBASE_AUTH_DOMAIN=replace-me.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=replace-me
VITE_FIREBASE_STORAGE_BUCKET=replace-me.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-me
VITE_FIREBASE_APP_ID=replace-me
VITE_FIREBASE_MEASUREMENT_ID=replace-me
# Optional server-side override for Firebase token verification (defaults to VITE_FIREBASE_API_KEY)
FIREBASE_WEB_API_KEY=replace-me

# Stripe billing
STRIPE_SECRET_KEY=replace-me
STRIPE_PUBLISHABLE_KEY=replace-me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_BASIC_MONTHLY=price_replace_basic
STRIPE_PRICE_PRO_MONTHLY=price_replace_pro
STRIPE_PRICE_PREMIUM_MONTHLY=price_replace_premium
STRIPE_PRICE_BASIC_ANNUAL=price_replace_basic_annual
STRIPE_PRICE_PRO_ANNUAL=price_replace_pro_annual
STRIPE_PRICE_PREMIUM_ANNUAL=price_replace_premium_annual
# Optional public base URL (defaults to request host)
BILLING_APP_BASE_URL=http://localhost:5173
# Optional billing API controls
BILLING_RATE_LIMIT_MAX=30
BILLING_RATE_LIMIT_WINDOW_MS=60000
BILLING_TIMEOUT_MS=15000
BILLING_AUTH_TIMEOUT_MS=10000
BILLING_ENABLE_AUTOMATIC_TAX=true
BILLING_REQUIRE_BILLING_ADDRESS=true
BILLING_ENABLE_TAX_ID_COLLECTION=true
BILLING_ENABLE_PHONE_COLLECTION=true
BILLING_TRIAL_DAYS=0
# For webhook-driven plan activation persistence into Firestore
FIREBASE_ADMIN_PROJECT_ID=replace-me
FIREBASE_ADMIN_CLIENT_EMAIL=replace-me@replace-me.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY=\"-----BEGIN PRIVATE KEY-----\\nreplace-me\\n-----END PRIVATE KEY-----\\n\"
# Optional, defaults to Google's token URI
FIREBASE_ADMIN_TOKEN_URI=https://oauth2.googleapis.com/token

# Optional: Supabase-backed billing store (preferred when configured)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_BILLING_TABLE=billing_profiles

# Translation API backend adapter
# Set provider to `google` or `azure`
TRANSLATE_PROVIDER=google

# Google Cloud Translation v2
GOOGLE_TRANSLATE_API_KEY=replace-me

# Azure Translator (only needed when TRANSLATE_PROVIDER=azure)
AZURE_TRANSLATOR_API_KEY=replace-me
AZURE_TRANSLATOR_REGION=replace-me
# Optional override, defaults to https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_ENDPOINT=

# Backend safety controls
TRANSLATE_RATE_LIMIT_MAX=60
TRANSLATE_RATE_LIMIT_WINDOW_MS=60000
TRANSLATE_TIMEOUT_MS=10000
TRANSLATE_MAX_TEXT_CHARS=1200
